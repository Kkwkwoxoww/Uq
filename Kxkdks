javascript:(function(){
    // رسالة التأكيد
    alert("✅ تم تشغيل سكربت الحظر الذكي! أي شخص يرسل الرموز سيتم مسح جميع رسائله اللاحقة...");

    const strictRegex = /^[█▓▒༺░▀▄\s]+$/;
    
    // ذاكرة السكربت (القائمة السوداء) لحفظ أسماء المخالفين
    const blacklistedUsers = new Set();

    function destroyMessage(node) {
        if (!node || node.nodeType !== 1) return;
        
        const containers = node.classList && node.classList.contains('uzr') ? [node] : node.querySelectorAll('.uzr');
        
        containers.forEach(container => {
            const msgBox = container.querySelector('.u-msg');
            // استخراج اسم المستخدم (في الغالب يكون داخل كلاس u-topic في هذه السكربتات)
            const nameBox = container.querySelector('.u-topic'); 
            
            if (msgBox) {
                const text = msgBox.textContent.trim();
                const userName = nameBox ? nameBox.textContent.trim() : null;
                
                // 1. هل الشخص موجود في القائمة السوداء مسبقاً؟
                const isBlacklisted = userName && blacklistedUsers.has(userName);
                
                // 2. هل الرسالة تحتوي على الرموز فقط؟
                const isForbidden = text.length > 0 && strictRegex.test(text);

                // إذا كان في القائمة السوداء، أو رسالته الحالية فيها رموز، نفذ الحذف!
                if (isBlacklisted || isForbidden) {
                    
                    // إذا هذي أول مرة يرسل الرموز، ضفه فوراً للقائمة السوداء
                    if (isForbidden && userName && !isBlacklisted) {
                        blacklistedUsers.add(userName);
                        console.log(`🚫 تم اصطياد [${userName}]. سيتم حذف جميع رسائله القادمة تلقائياً.`);
                    }
                    
                    // إخفاء الرسالة فوراً (Zero-delay)
                    container.style.display = 'none';
                    
                    // الضغط على زر الحذف الخاص برسالته
                    const delBtn = container.querySelector('#delmsg');
                    if (delBtn) {
                        delBtn.click();
                    }
                }
            }
        });
    }

    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
                setTimeout(() => destroyMessage(node), 50);
            });
        });
    });

    const wall = document.getElementById('d2bc');
    const chat = document.getElementById('d2');
    
    if(wall) observer.observe(wall, { childList: true, subtree: true });
    if(chat) observer.observe(chat, { childList: true, subtree: true });
    if(!wall && !chat) observer.observe(document.body, { childList: true, subtree: true });

    destroyMessage(document.body);
})();
