javascript:(function(){
    // تنظيف أي حظر سابق قد يكون علق على اسمك
    localStorage.removeItem('turbo_my_name');
    alert("⚡ تم تفعيل نظام التصفية الآمن! (الآن يمكنك الإرسال بحرية تامة دون تدخل السكربت).");

    const strictRegex = /^[█كت▀▄\s]+$/;
    const blacklistedHashes = new Set();

    function nukeMessage(container) {
        // إخفاء بصري فقط - لا نلمس زر الإرسال ولا نضغط على أي شيء
        container.style.setProperty('display', 'none', 'important');
        container.style.setProperty('opacity', '0', 'important');
    }

    function scanAndDestroy(node) {
        if (!node || node.nodeType !== 1) return;
        
        const containers = node.classList && node.classList.contains('uzr') ? [node] : node.querySelectorAll('.uzr');
        
        for (let i = 0; i < containers.length; i++) {
            const container = containers[i];
            
            // 1. حماية "رسائلي": إذا كان العنصر يحتوي على كلاس يخص "رسائلي" (مثل kmsg)، لا تلمسه!
            if (container.classList.contains('kmsg') || container.querySelector('.my-msg')) {
                continue;
            }

            const msgBox = container.querySelector('.u-msg');
            const hashBox = container.querySelector('.uhash');
            
            if (!msgBox) continue;

            const text = msgBox.textContent.trim();
            const userHash = hashBox ? hashBox.textContent.trim() : "";

            // الفحص
            const isBlacklisted = (userHash && blacklistedHashes.has(userHash));
            const isForbidden = text.length > 0 && strictRegex.test(text);

            if (isBlacklisted || isForbidden) {
                nukeMessage(container);
                if (isForbidden && userHash) {
                    blacklistedHashes.add(userHash);
                }
            }
        }
    }

    const observer = new MutationObserver((mutations) => {
        mutations.forEach(m => m.addedNodes.forEach(scanAndDestroy));
    });

    observer.observe(document.body, { childList: true, subtree: true });
    scanAndDestroy(document.body);
})();
